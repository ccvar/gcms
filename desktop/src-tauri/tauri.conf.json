{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GCMS Pilot",
  "version": "0.2.21",
  "identifier": "com.ccvar.gcms.pilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "GCMS Pilot",
        "width": 820,
        "height": 560,
        "minWidth": 820,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "本地 AI 内容驾驶舱",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ccvar/gcms-pilot-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3QzYxRkM4MjlDQ0FDRUEKUldUcXJNd3B5Qi9HaDRwdUVuMW9SeEtoWW1KSEt1N1U2SXJOVzdrdi9tbFdQd3R3SEV3MzNwMFoK"
    }
  }
}
