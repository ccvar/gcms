{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and connection workspaces",
  "windows": ["main", "conn-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "dialog:default",
    "notification:default",
    "updater:default",
    "process:default"
  ]
}
